{
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "Redis": {
    "DefaultTtlMinutes": 30
  },
  "ExternalApi": {
    "BaseUrl": "http://localhost:8081/api/external-resource",
    "CacheKeyQueryParam": "key",
    "TimeoutSeconds": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
